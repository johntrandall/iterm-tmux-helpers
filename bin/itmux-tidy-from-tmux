#!/usr/bin/env python3
"""
tmux-iterm-tidy: regroup iTerm tmux-backed tabs so each tmux session has
its own iTerm window, with its tmux windows as tabs in tmuxWindow-ID order.

Use after drag-and-drop reshuffling has scattered tmux session tabs across
multiple iTerm windows, or when one iTerm window holds tabs from several
sessions. Reads current iTerm state, decides the desired layout, applies it.

Does NOT attach any detached sessions — pair with `tmux-attach-all` for that.
Does NOT touch non-tmux iTerm tabs.

Default: dry-run (lists planned moves). Pass --apply to actually rearrange.
"""

import argparse
import asyncio
import os
import subprocess
import sys

import iterm2

sys.path.insert(0, os.path.dirname(os.path.realpath(__file__)))
from _version_check import warn_if_versions_unverified  # noqa: E402
warn_if_versions_unverified()

TMUX = "/opt/homebrew/bin/tmux"


def tmux_window_to_session_map():
    """Return {tmux_window_id_int: session_name} for every window on the server.

    tmux window IDs are like '@20'; we strip the '@' and return as int to match
    iTerm's `tmuxWindow` variable (which is the integer form).
    """
    r = subprocess.run(
        [TMUX, "list-windows", "-a", "-F", "#{window_id}\t#{session_name}"],
        capture_output=True, text=True,
    )
    out = {}
    for line in r.stdout.strip().split("\n"):
        if not line:
            continue
        wid, sess = line.split("\t", 1)
        wid = wid.lstrip("@")
        try:
            out[int(wid)] = sess
        except ValueError:
            continue
    return out


async def gather_layout(app, wid_to_session):
    """Build {session_name: [(tmux_window_id, tab, source_window), ...]}."""
    by_session = {}
    for w in app.terminal_windows:
        for tab in list(w.tabs):
            tw_var = await tab.async_get_variable("tmuxWindow")
            if tw_var is None:
                continue
            try:
                tw_id = int(tw_var)
            except (TypeError, ValueError):
                continue
            if tw_id < 0:
                continue
            sess = wid_to_session.get(tw_id)
            if not sess:
                continue
            by_session.setdefault(sess, []).append((tw_id, tab, w))
    for sess in by_session:
        by_session[sess].sort(key=lambda x: x[0])
    return by_session


def is_clean(session_entries):
    """True if all session tabs are in one iTerm window AND that window holds only session tabs."""
    if not session_entries:
        return True
    windows = {w.window_id for _, _, w in session_entries}
    if len(windows) != 1:
        return False
    only_window = session_entries[0][2]
    return len(list(only_window.tabs)) == len(session_entries)


async def main(connection, apply):
    app = await iterm2.async_get_app(connection)
    wid_to_session = tmux_window_to_session_map()
    by_session = await gather_layout(app, wid_to_session)

    if not by_session:
        print("No tmux-backed iTerm tabs found.")
        return

    plan = []
    for sess, entries in by_session.items():
        if is_clean(entries):
            print(f"  {sess}: already clean ({len(entries)} tabs)")
            continue
        plan.append((sess, entries))
        n_windows = len({w.window_id for _, _, w in entries})
        print(f"  {sess}: {len(entries)} tabs across {n_windows} window(s) "
              f"→ regroup into a fresh iTerm window")

    if not plan:
        print("\nNothing to do — all sessions already tidy.")
        return

    if not apply:
        print("\n(dry-run) — pass --apply to actually rearrange.")
        return

    # Fresh-window strategy: for each unclean session, extract its first tab
    # into a brand-new iTerm window via async_move_to_window(), then call
    # async_set_tabs() on that new window to consolidate the rest.
    #
    # Why a fresh window per session and not "pick the dominant window":
    # if two sessions share one mixed iTerm window, picking that window as
    # destination for both produces a sequential ping-pong — each session's
    # async_set_tabs() displaces the other's tabs back into its own (now-
    # newly-empty) source window. Fresh windows guarantee no two sessions
    # ever share a destination, so foreign tabs are never disturbed by the
    # wrong session's iteration.
    #
    # Re-evaluating cleanliness mid-loop: when N sessions share one mixed
    # iTerm window, processing N-1 of them displaces foreign tabs out of
    # that window, leaving the Nth session as the sole occupant. The Nth
    # session is then already in its own pure window and needs no move.
    # Without the re-check, async_move_to_window() would fail with "Window
    # has only one tab" — iTerm refuses to move a tab if doing so would
    # leave the source window empty.
    print()
    for sess, entries in plan:
        await app.async_refresh()
        if is_clean(entries):
            print(f"  ⊙ {sess}: became clean during apply (foreign tabs "
                  f"displaced by earlier sessions) — no move needed")
            continue
        ordered_tabs = [tab for _, tab, _ in entries]
        try:
            new_window = await ordered_tabs[0].async_move_to_window()
            if new_window is None:
                print(f"  ✗ {sess}: async_move_to_window returned None",
                      file=sys.stderr)
                continue
            if len(ordered_tabs) > 1:
                await new_window.async_set_tabs(ordered_tabs)
            print(f"  ✓ {sess}: regrouped {len(ordered_tabs)} tab(s) "
                  f"into fresh window {new_window.window_id}")
        except Exception as e:
            print(f"  ✗ {sess}: {e}", file=sys.stderr)

    print("\nDone.")


def parse_args():
    p = argparse.ArgumentParser(description=__doc__.split("\n")[1])
    p.add_argument("--apply", action="store_true",
                   help="actually rearrange (default is dry-run)")
    return p.parse_args()


if __name__ == "__main__":
    args = parse_args()
    iterm2.run_until_complete(lambda c: main(c, args.apply))
