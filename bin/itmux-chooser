#!/bin/zsh
# tmux session chooser for iTerm2 CC mode
# Runs as iTerm profile command. Shows session tree with arrow-key navigation.
#
# Usage: Set as iTerm profile command (Settings -> Profiles -> General -> Command)
#   Up/Down  navigate
#   Enter:
#     session line  → attach session (or focus if already open)
#     window line   → attach session + focus that window
#     [+ new]       → create new session
#     [refresh]     → reload session/window list
#   Type  filter
#   Esc   drop to plain shell
#
# Loops back to picker after focusing an existing session or refreshing.

# Resolve tmux + fzf at runtime so we work on Intel/Apple-Silicon Homebrew,
# MacPorts, source installs, etc. Override with TMUX_BIN / FZF_BIN env vars.
TMUX="${TMUX_BIN:-$(command -v tmux)}"
FZF="${FZF_BIN:-$(command -v fzf)}"
[[ -z "$TMUX" ]] && { print -u2 "error: tmux not found on PATH (set TMUX_BIN to override)"; exit 1; }
[[ -z "$FZF" ]]  && { print -u2 "error: fzf not found on PATH (set FZF_BIN to override)"; exit 1; }
SEP='§'

# Version warning (non-fatal). Suppressed by ITMUX_SUPPRESS_VERSION_WARN=1.
VERIFIED_TMUX_VERSION="3.6a"
VERIFIED_ITERM_VERSION="3.6"
if [[ -z "${ITMUX_SUPPRESS_VERSION_WARN:-}" ]]; then
  _tmux_v="$($TMUX -V 2>/dev/null | awk '{print $2}')"
  _iterm_v="$(defaults read /Applications/iTerm.app/Contents/Info.plist CFBundleShortVersionString 2>/dev/null)"
  _iterm_mm="${_iterm_v%.*}"
  _issues=()
  [[ -n "$_tmux_v" && "$_tmux_v" != "$VERIFIED_TMUX_VERSION" ]] && _issues+=("tmux $_tmux_v (verified: $VERIFIED_TMUX_VERSION)")
  [[ -n "$_iterm_v" && "$_iterm_mm" != "$VERIFIED_ITERM_VERSION" ]] && _issues+=("iTerm2 $_iterm_v (verified: ${VERIFIED_ITERM_VERSION}.x)")
  if (( ${#_issues[@]} > 0 )); then
    print -u2 "⚠ itmux: untested against ${(j: and :)_issues} — behavior may differ. Set ITMUX_SUPPRESS_VERSION_WARN=1 to silence."
  fi
fi

# Check if a tmux session has a CC (control mode) client attached
has_cc_client() {
  $TMUX list-clients -t "$1" -F '#{client_control_mode}' 2>/dev/null | grep -q '^1$'
}

# Focus the iTerm window mirroring a tmux CC session.
# iTerm names CC windows "↣ <session>: <window> ..."; match on that prefix.
# Returns 0 if focused, 1 if not found.
focus_cc_session() {
  local session="$1"
  local prefix="↣ ${session}:"
  local result
  result=$(osascript <<EOF 2>/dev/null
tell application "iTerm2"
  set targetPrefix to "$prefix"
  repeat with w in windows
    if name of w starts with targetPrefix then
      select w
      return "focused"
    end if
  end repeat
  return "notfound"
end tell
EOF
  )
  [[ "$result" == "focused" ]]
}

while true; do

sessions=$($TMUX ls -F '#{session_name}' 2>/dev/null)

if [[ -z "$sessions" ]]; then
  printf "No tmux sessions running.\n\n"
  printf "New session name [main]: "
  read name
  [[ -z "$name" ]] && name="main"
  exec $TMUX -CC new-session -s "$name"
fi

# Build tree: hidden prefix = session_name%%action%%display
tree=""
while IFS= read -r s; do
  if has_cc_client "$s"; then
    attached=" \033[33m(open in iTerm)\033[0m"
  elif $TMUX ls -F '#{session_name}:#{?session_attached,1,0}' 2>/dev/null \
       | grep -q "^${s}:1$"; then
    attached=" (attached)"
  else
    attached=""
  fi
  tree+="${s}${SEP}_NEW_WINDOW_${SEP}\033[1m${s}\033[0m${attached}\n"
  $TMUX list-windows -t "$s" -F '#{window_index}:#{window_name}:#{?window_active,*,}' 2>/dev/null \
    | while IFS=: read -r widx wname wactive; do
        cmds=$($TMUX list-panes -t "$s:$widx" -F '#{pane_current_command}' 2>/dev/null \
          | paste -sd, - | sed 's/,/, /g')
        unique_cmds=$(echo "$cmds" | tr ', ' '\n' | grep -v '^$' | sort -u)
        if [[ "$unique_cmds" == "$wname" ]]; then
          npanes=$($TMUX list-panes -t "$s:$widx" -F x 2>/dev/null | wc -l | tr -d ' ')
          if (( npanes > 1 )); then
            detail="${npanes} panes"
          else
            detail=""
          fi
        else
          detail="$cmds"
        fi
        if [[ -n "$detail" ]]; then
          tree+="${s}${SEP}${widx}${SEP}      \033[2m${widx}: ${wname} (${detail})${wactive}\033[0m\n"
        else
          tree+="${s}${SEP}${widx}${SEP}      \033[2m${widx}: ${wname}${wactive}\033[0m\n"
        fi
      done
done <<< "$sessions"
tree+="_NEW_SESSION_${SEP}_NEW_SESSION_${SEP}\033[1m[+ new session]\033[0m"
tree+="_REFRESH_${SEP}_REFRESH_${SEP}\033[2m[↻ refresh]\033[0m"

selection=$(printf "$tree" \
  | $FZF --ansi \
         --delimiter="$SEP" \
         --with-nth=3.. \
         --prompt="tmux> " \
         --header="enter select/focus · type filter · esc shell" \
         --reverse \
         --no-info)

session_name=$(echo "$selection" | awk -F"$SEP" '{print $1}')
action=$(echo "$selection" | awk -F"$SEP" '{print $2}')

if [[ "$session_name" == "_REFRESH_" ]]; then
  continue
elif [[ -z "$session_name" ]]; then
  exec /bin/zsh -l
elif [[ "$session_name" == "_NEW_SESSION_" ]]; then
  printf "Session name: "
  read name
  [[ -z "$name" ]] && name="session-$(date +%s)"
  exec $TMUX -CC new-session -s "$name"
elif has_cc_client "$session_name"; then
  # Session already open in iTerm — focus that window, loop back to picker
  if [[ "$action" != "_NEW_WINDOW_" ]]; then
    $TMUX select-window -t "$session_name:$action" 2>/dev/null
  fi
  if ! focus_cc_session "$session_name"; then
    printf "\033[31mCouldn't find iTerm window for '%s'\033[0m\n" "$session_name"
    sleep 1
  fi
  continue
elif [[ "$action" == "_NEW_WINDOW_" ]]; then
  # Session line: attach to existing windows. Do NOT create a new window —
  # that produced a spurious "zsh"-named tab on every session-level pick.
  exec $TMUX -CC new-session -A -s "$session_name"
else
  # Window line: focus that window, then attach
  $TMUX select-window -t "$session_name:$action"
  exec $TMUX -CC new-session -A -s "$session_name"
fi

done  # end refresh loop
